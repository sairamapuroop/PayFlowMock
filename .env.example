# Copy to `.env` and change values. Docker Compose and the app read these (see README).
# Never commit `.env`.

# PostgreSQL (used by docker-compose `postgres` service)
POSTGRES_USER=payflow
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=PayFlowMock

# App: connection string must match POSTGRES_* above when using local Compose Postgres
DATABASE_URL=postgres://payflow:change_me_strong_password@127.0.0.1:5432/PayFlowMock?sslmode=disable

# Integration tests (`make test-integration`): PostgreSQL DSN for a separate database so tests can
# migrate, truncate tables, and exercise the schema without touching the dev DB. Create the DB once
# (e.g. `CREATE DATABASE PayFlowMockTest;`) and align user/password/host with DATABASE_URL or Compose.
# `make test-unit` uses `go test -short` and skips tests that call this URL. Unset skips integration tests.
TEST_DATABASE_URL=postgres://payflow:change_me_strong_password@127.0.0.1:5432/PayFlowMockTest?sslmode=disable

# Optional: if set, `/v1/*` requires X-API-Key or Authorization: Bearer <API_KEY>
API_KEY=change_me_api_key

# HTTP port for `go run ./cmd/server`
PORT=8080

# Postgres idempotency lease when Redis is down (Go duration: 60s, 2m). Unset uses 60s.
# Should exceed the slowest mutating request (PSP + DB).
IDEMPOTENCY_REQUEST_TIMEOUT=60s

# --- Webhooks (outbox worker POSTs to merchant URLs; see internal/merchant/registry.go)
# Optional: comma-separated uuid=https://... pairs (whitespace after commas is fine).
MERCHANT_WEBHOOK_URLS=
# Fallback URL when no MERCHANT_WEBHOOK_URLS entry matches the payment merchant_id.
# For local manual testing, run `make webhook-sink` and use http://127.0.0.1:9999/webhook
DEFAULT_WEBHOOK_URL=http://127.0.0.1:9999/webhook
# Shared HMAC secret for X-PayFlow-Signature (sha256=...). Leave empty to omit signing.
WEBHOOK_SIGNING_SECRET=
# Worker poll interval (Go duration: 5s, 1m, etc.). Unset uses the built-in default (5s).
WEBHOOK_POLL_INTERVAL=5s

# --- Observability (OpenTelemetry + structured logs)
# OTLP HTTP endpoint for traces (use http://jaeger:4318 inside Docker Compose; localhost when exporting to host Jaeger).
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# Resource attribute service.name (see cmd/server/main.go)
OTEL_SERVICE_NAME=payflow
# Parent-based trace ID ratio sampler argument in [0.0, 1.0]; 1.0 = always sample roots in dev.
OTEL_TRACES_SAMPLER_ARG=1.0
# Optional OpenTelemetry resource attributes (see pkg/tracer/tracer.go)
# OTEL_SERVICE_VERSION=dev
# OTEL_DEPLOYMENT_ENV=dev

# Zerolog level: trace, debug, info, warn, error, fatal, panic, disabled
LOG_LEVEL=info

# Optional: separate metrics listener (not implemented — Prometheus scrapes /metrics on the main HTTP server).
# METRICS_ADDR=:9091

# Grafana UI (docker-compose defaults; override before `make stack-up` if desired)
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
