# Copy to `.env` and change values. Docker Compose and the app read these (see README).
# Never commit `.env`.

# PostgreSQL (used by docker-compose `postgres` service)
POSTGRES_USER=payflow
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=PayFlowMock

# App: connection string must match POSTGRES_* above when using local Compose Postgres
DATABASE_URL=postgres://payflow:change_me_strong_password@127.0.0.1:5432/PayFlowMock?sslmode=disable

# Optional: if set, `/v1/*` requires X-API-Key or Authorization: Bearer <API_KEY>
API_KEY=change_me_api_key

# HTTP port for `go run ./cmd/server`
PORT=8080

# Postgres idempotency lease when Redis is down (Go duration: 60s, 2m). Unset uses 60s.
# Should exceed the slowest mutating request (PSP + DB).
IDEMPOTENCY_REQUEST_TIMEOUT=60s

# --- Webhooks (outbox worker POSTs to merchant URLs; see internal/merchant/registry.go)
# Optional: comma-separated uuid=https://... pairs (whitespace after commas is fine).
MERCHANT_WEBHOOK_URLS=
# Fallback URL when no MERCHANT_WEBHOOK_URLS entry matches the payment merchant_id.
# For local manual testing, run `make webhook-sink` and use http://127.0.0.1:9999/webhook
DEFAULT_WEBHOOK_URL=http://127.0.0.1:9999/webhook
# Shared HMAC secret for X-PayFlow-Signature (sha256=...). Leave empty to omit signing.
WEBHOOK_SIGNING_SECRET=
# Worker poll interval (Go duration: 5s, 1m, etc.). Unset uses the built-in default (5s).
WEBHOOK_POLL_INTERVAL=5s
